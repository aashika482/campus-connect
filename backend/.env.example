# Copy this to .env and fill in your values
# NEVER commit .env to git

# Neon PostgreSQL — get this from your Neon dashboard > Connection string
DATABASE_URL=postgresql+asyncpg://username:password@ep-xxxx.ap-southeast-1.aws.neon.tech/neondb?sslmode=require

# JWT — generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=your-super-secret-key-change-this

# Optional
DEBUG=False

# Production: set this to your deployed frontend URL (e.g. https://campulse.vercel.app)
FRONTEND_URL=
