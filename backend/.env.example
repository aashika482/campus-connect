# Copy this to .env and fill in your values
# NEVER commit .env to git

# Neon PostgreSQL — get this from your Neon dashboard > Connection string
DATABASE_URL=postgresql://username:password@ep-xxxx.us-east-2.aws.neon.tech/campulse?sslmode=require

# JWT — generate with: openssl rand -hex 32
JWT_SECRET_KEY=your-super-secret-key-change-this

# Optional
DEBUG=False
